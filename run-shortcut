#!/bin/bash
# run-shortcut - Universal Macro Engine for Kapcode Infrastructure
# Version: 1.9.1 (Management Shielding Fix)

SCRIPT_NAME=$(basename "$0")
[ "$SCRIPT_NAME" != "run-shortcut" ] && { echo "❌ Error: Rename to 'run-shortcut'"; exit 1; }

TARGET_BIN="/usr/local/bin/run-shortcut"
LAUNCHER_DIR="$HOME/.local/share/applications"
WRAPPER_DIR="$HOME/.local/bin"

# --- 1. THE HUD ENGINE (Balanced Padding) ---
show_hud() {
    local msg="$1"
    if [[ "$use_osd" -eq 1 ]] && command -v osd_cat >/dev/null 2>&1; then
        [[ -z "$DISPLAY" ]] && export DISPLAY=$(ls /tmp/.X11-unix/X* 2>/dev/null | head -n1 | sed 's/.*X/:/')
        local padded_label="    [Kapcode] ⚡ $msg    " 
        char_count=${#padded_label}
        screen_width=$(xrandr 2>/dev/null | grep '*' | head -n1 | awk '{print $1}' | cut -d'x' -f1 || echo "1920")
        dynamic_indent=$((screen_width - (char_count * 12) - 80))
        (echo "$padded_label" | osd_cat --pos=bottom --align=left --offset=45 --indent=$dynamic_indent \
            --colour="$hud_color" --shadow=2 --outline=1 --lines=1 \
            --font="-*-fixed-bold-r-*-*-18-*-*-*-*-*-*-*" --delay=2) &
    fi
}

# --- 2. PRIORITY MANAGEMENT (Exit Early) ---
do_uninstall() {
    echo -e "\033[0;34mCleaning environment...\033[0m"
    rm -f "$LAUNCHER_DIR"/rs-*.desktop
    rm -f "$WRAPPER_DIR"/rs-wrap-*
    sudo rm -f "$TARGET_BIN" "/etc/udev/rules.d/80-run-shortcut-uinput.rules"
    echo "✅ Cleaned."
}

if [[ "$1" == "--uninstall" ]]; then do_uninstall; exit 0; fi

if [[ "$1" == "--install" ]]; then
    sudo cp "$0" "$TARGET_BIN" && sudo chmod +x "$TARGET_BIN"
    echo 'KERNEL=="uinput", GROUP="input", MODE="0660", OPTIONS+="static_node=uinput"' | sudo tee "/etc/udev/rules.d/80-run-shortcut-uinput.rules" > /dev/null
    ! groups "$USER" | grep -q "\binput\b" && sudo usermod -aG input "$USER"
    echo "✅ Installed."; exit 0
fi

if [[ "$1" == "--reinstall" ]]; then
    SOURCE_SCRIPT=$(realpath "$0")
    do_uninstall
    sudo cp "$SOURCE_SCRIPT" "$TARGET_BIN" && sudo chmod +x "$TARGET_BIN"
    echo "✅ Reinstall Successful."; exit 0
fi

if [[ "$1" == "--make-launcher" ]]; then
    APP_NAME="$2"; APP_FLAGS="$3"; APP_KEYS="$4"
    mkdir -p "$LAUNCHER_DIR" "$WRAPPER_DIR"
    ID=$(echo "$APP_NAME" | tr '[:upper:]' '[:lower:]' | tr ' ' '-' | sed 's/[^a-z0-9-]//g')
    WRAPPER="$WRAPPER_DIR/rs-wrap-$ID"
    cat <<EOF > "$WRAPPER"
#!/bin/bash -l
exec > "/tmp/rs-$ID.log" 2>&1
[ -z "\$DISPLAY" ] && export DISPLAY=\$(ls /tmp/.X11-unix/X* | head -n1 | sed 's/.*X/:/')
[ -S "/tmp/.ydotool_socket" ] && export YDOTOOL_SOCKET="/tmp/.ydotool_socket"
$TARGET_BIN $APP_FLAGS "$APP_KEYS"
EOF
    chmod +x "$WRAPPER"
    cat <<EOF > "$LAUNCHER_DIR/rs-$ID.desktop"
[Desktop Entry]
Type=Application
Name=$APP_NAME
Exec=$WRAPPER
Icon=input-keyboard
Terminal=false
Categories=Utility;Automation;
EOF
    update-desktop-database "$LAUNCHER_DIR"
    echo "✅ Created Launcher: $APP_NAME"; exit 0
fi

if [[ "$1" == "--remove-launcher" ]]; then
    ID=$(echo "$2" | tr '[:upper:]' '[:lower:]' | tr ' ' '-' | sed 's/[^a-z0-9-]//g')
    rm -f "$LAUNCHER_DIR/rs-$ID.desktop" "$WRAPPER_DIR/rs-wrap-$ID"
    echo "✅ Removed: $ID"; exit 0
fi

# --- 3. EXECUTION LOGIC ---
[ -z "$WAYLAND_DISPLAY" ] && tool="xdotool" || tool="ydotool"
delay=0; use_osd=0; use_record=0; hud_color="#00FFFF"
mouse_x=""; mouse_y=""; mouse_click=""

while [[ $# -gt 0 ]]; do
    case "$1" in
        --record) use_record=1; shift ;;
        --osd) use_osd=1; shift ;;
        --color) hud_color="$2"; shift 2 ;;
        -m|--move) mouse_x="$2"; mouse_y="$3"; shift 3 ;;
        -c|--click) mouse_click="$2"; shift 2 ;;
        -d|--delay) delay="$2"; shift 2 ;;
        *) break ;;
    esac
done

# Deep Recorder Branch
if [[ "$use_record" -eq 1 ]]; then
    echo -e "\033[0;33m⏺️  Kapcode Deep Recorder Active.\033[0m"
    sudo libinput debug-events --show-keycodes 2>/dev/null | stdbuf -oL grep "POINTER_BUTTON" | while read -r line; do
        if echo "$line" | grep -q "pressed"; then
            X=$(xdotool getmouselocation 2>/dev/null | grep -oP 'x:\K\d+')
            Y=$(xdotool getmouselocation 2>/dev/null | grep -oP 'y:\K\d+')
            if [ -n "$X" ]; then
                echo -e "\033[0;32m[CAPTURED] X=$X, Y=$Y\033[0m"
                show_hud "$X, $Y"
                echo "run-shortcut -m $X $Y -c 1"
            fi
        fi
    done
    exit 0
fi

# Standard Execution
[[ "$tool" == "ydotool" ]] && { pgrep -x "ydotoold" >/dev/null || { nohup ydotoold >/dev/null 2>&1 & sleep 0.5; }; }
shortcut="$1"
[ -n "$shortcut" ] && show_hud "$shortcut"
[ "$delay" -gt 0 ] && sleep "$(awk "BEGIN {print $delay/1000}")"

[ -n "$mouse_x" ] && { [[ "$tool" = "xdotool" ]] && xdotool mousemove "$mouse_x" "$mouse_y" || ydotool move "$mouse_x" "$mouse_y"; }
if [ -n "$mouse_click" ]; then
    if [[ "$tool" == "xdotool" ]]; then xdotool click "$mouse_click"
    else
        case "$mouse_click" in 1) b="0xC0";; 2) b="0xC2";; 3) b="0xC1";; esac
        ydotool click "$b"
    fi
fi

# Keyboard Sequence
read -ra keys <<< "$shortcut"
if [ ${#keys[@]} -gt 0 ]; then
    if [[ "$tool" == "ydotool" ]]; then
        seq=""; for k in "${keys[@]}"; do [ -z "$seq" ] && seq="$k" || seq="$seq+$k"; done
        ydotool key "$seq"
    else
        for ((i=0; i<${#keys[@]}-1; i++)); do xdotool keydown "${keys[i]}"; done
        xdotool key "${keys[-1]}"; for ((i=${#keys[@]}-2; i>=0; i--)); do xdotool keyup "${keys[i]}"; done
    fi
fi
