#!/bin/bash
# run-shortcut - universal keyboard/mouse macro utility for Kapcode Infrastructure
# Version: 1.3.2 (Shielded Management Logic)

# --- STRICT NAMING ENFORCEMENT ---
SCRIPT_NAME=$(basename "$0")
if [ "$SCRIPT_NAME" != "run-shortcut" ]; then
    echo "❌ Error: Invalid filename detected ('$SCRIPT_NAME')." >&2
    echo "This tool must be named exactly 'run-shortcut' to function." >&2
    exit 1
fi

TARGET_BIN="/usr/local/bin/run-shortcut"
LAUNCHER_DIR="$HOME/.local/share/applications"

# --- 1. PRIORITY MANAGEMENT COMMANDS (Exit early) ---
if [ "$1" = "--install" ]; then
    echo "📦 Installing run-shortcut to $TARGET_BIN..."
    sudo cp "$0" "$TARGET_BIN" && sudo chmod +x "$TARGET_BIN"
    echo 'KERNEL=="uinput", GROUP="input", MODE="0660", OPTIONS+="static_node=uinput"' | sudo tee "/etc/udev/rules.d/80-run-shortcut-uinput.rules" > /dev/null
    ! groups "$USER" | grep -q "\binput\b" && sudo usermod -aG input "$USER"
    echo "✅ Permissions & Binary installed. Please reboot for full Wayland support."
    exit 0
fi

if [ "$1" = "--uninstall" ]; then
    sudo rm -f "$TARGET_BIN" "/etc/udev/rules.d/80-run-shortcut-uinput.rules"
    echo "✅ Uninstalled."
    exit 0
fi

if [ "$1" = "--make-launcher" ]; then
    APP_NAME="$2"; APP_FLAGS="$3"; APP_KEYS="$4"
    mkdir -p "$LAUNCHER_DIR" "$HOME/.local/bin"
    SAFE_NAME=$(echo "$APP_NAME" | tr '[:upper:]' '[:lower:]' | tr ' ' '-' | sed 's/[^a-z0-9-]//g')
    WRAPPER_PATH="$HOME/.local/bin/rs-wrap-$SAFE_NAME"
    cat <<EOF > "$WRAPPER_PATH"
#!/bin/bash -l
exec > "/tmp/rs-$SAFE_NAME.log" 2>&1
[ -S "/tmp/.ydotool_socket" ] && export YDOTOOL_SOCKET="/tmp/.ydotool_socket"
[ -S "\$XDG_RUNTIME_DIR/.ydotool_socket" ] && export YDOTOOL_SOCKET="\$XDG_RUNTIME_DIR/.ydotool_socket"
$TARGET_BIN $APP_FLAGS "$APP_KEYS"
EOF
    chmod +x "$WRAPPER_PATH"
    cat <<EOF > "$LAUNCHER_DIR/rs-$SAFE_NAME.desktop"
[Desktop Entry]
Type=Application
Name=$APP_NAME
Exec=$WRAPPER_PATH
Icon=input-keyboard
Terminal=false
Categories=Utility;Automation;
EOF
    update-desktop-database "$LAUNCHER_DIR"
    echo "✅ Launcher Created: $APP_NAME"; exit 0
fi

if [ "$1" = "--list-launchers" ]; then
    echo "Managed Launchers:"
    for f in "$LAUNCHER_DIR"/rs-*.desktop; do
        [ -e "$f" ] && echo " • $(grep '^Name=' "$f" | cut -d= -f2) ($(basename "$f" .desktop | sed 's/rs-//'))"
    done; exit 0
fi

if [ "$1" = "--remove-launcher" ]; then
    # Improved ID matching
    ID=$(echo "$2" | tr '[:upper:]' '[:lower:]' | tr ' ' '-' | sed 's/[^a-z0-9-]//g')
    rm -f "$LAUNCHER_DIR/rs-$ID.desktop" "$HOME/.local/bin/rs-wrap-$ID"
    echo "✅ Removed launcher: $ID"; exit 0
fi

# --- 2. MACRO EXECUTION LOGIC (Standard Flags) ---
[ -z "$WAYLAND_DISPLAY" ] && tool="xdotool" || tool="ydotool"

delay_before=0; autowait=0; verbose=0; use_osd=0
mouse_x=""; mouse_y=""; mouse_click=""

while [[ $# -gt 0 ]]; do
    case "$1" in
        -v|--verbose) verbose=1; shift ;;
        --osd) use_osd=1; shift ;;
        -m|--move) mouse_x="$2"; mouse_y="$3"; shift 3 ;;
        -c|--click) mouse_click="$2"; shift 2 ;;
        -d|--delay) delay_before="$2"; shift 2 ;;
        -aw|--autowait) autowait="$2"; shift 2 ;;
        -h|--help) # Full help section
            echo "Macro tool. Flags: --osd, -m X Y, -c BTN, -d MS, -v"; exit 0 ;;
        *) break ;;
    esac
done

# Ensure daemon is running for ydotool
if [[ "$tool" == "ydotool" ]]; then
    pgrep -x "ydotoold" > /dev/null || { nohup ydotoold > /dev/null 2>&1 & sleep 0.5; }
fi

shortcut="$1"
read -ra keys <<< "$shortcut"

if [ "$use_osd" -eq 1 ]; then
    label="${shortcut:-"Mouse Action"}"
    if command -v osd_cat >/dev/null 2>&1; then
        echo "⚡ MACRO: $label" | osd_cat --pos=bottom --align=right --offset=40 --indent=40 \
            --color=red --font="-adobe-helvetica-bold-r-normal--24-240-75-75-p-138-iso8859-1" \
            --delay=2 &
    fi
fi

[ "$delay_before" -gt 0 ] && sleep "$(awk "BEGIN {print $delay_before/1000}")"

# Execute Mouse Move
[ -n "$mouse_x" ] && { [ "$tool" = "xdotool" ] && xdotool mousemove "$mouse_x" "$mouse_y" || ydotool mousemove -a "$mouse_x" "$mouse_y"; }
# Execute Mouse Click
if [ -n "$mouse_click" ]; then
    [ "$tool" = "xdotool" ] && xdotool click "$mouse_click" || {
        case "$mouse_click" in 1) b="0xC0";; 2) b="0xC2";; 3) b="0xC1";; esac
        ydotool click "$b"
    }
fi

# Execute Keys
if [ ${#keys[@]} -gt 0 ]; then
    if [ "$tool" = "ydotool" ]; then
        seq=""
        for k in "${keys[@]}"; do [ -z "$seq" ] && seq="$k" || seq="$seq+$k"; done
        ydotool key "$seq"
    else
        for ((i=0; i<${#keys[@]}-1; i++)); do xdotool keydown "${keys[i]}"; done
        xdotool key "${keys[-1]}"; for ((i=${#keys[@]}-2; i>=0; i--)); do xdotool keyup "${keys[i]}"; done
    fi
fi
