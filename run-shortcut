#!/bin/bash
# run-shortcut - Universal Macro Engine for Kapcode Infrastructure
# Version: 1.6.0 (Smart Monitor Probing & Dynamic HUD Indent)

SCRIPT_NAME=$(basename "$0")
[ "$SCRIPT_NAME" != "run-shortcut" ] && { echo "❌ Error: Rename to 'run-shortcut'"; exit 1; }

TARGET_BIN="/usr/local/bin/run-shortcut"

# --- 1. MONITOR PROBING ---
get_monitor_info() {
    # Probes Wayland for active monitor dimensions
    if command -v wlrctl >/dev/null 2>&1; then
        # Extracts width of the primary/active surface
        wlrctl toplevel list | grep -oP '\d+x\d+' | head -n1 | cut -d'x' -f1
    else
        # Fallback to a standard 1080p width if probing fails
        echo "1920"
    fi
}

# --- 2. RECORDING MODE ---
if [[ "$1" == "--record" ]]; then
    echo -e "\033[0;33m⏺️  Kapcode Recorder: Capture click coordinates\033[0m"
    if [ -n "$WAYLAND_DISPLAY" ]; then
        echo "Wayland (Pop!_OS) detected. Probing libinput..."
        sudo libinput debug-events --show-keycodes | stdbuf -oL grep "POINTER_BUTTON" | while read -r line; do
            echo -e "\033[0;32mClick Detected!\033[0m"
            echo "Use 'wlrctl pointer move' output for exact target."
        done
    else
        watch -n 0.1 "xdotool getmouselocation --shell"
    fi
    exit 0
fi

# --- 3. MANAGEMENT ---
if [[ "$1" == "--reinstall" ]]; then
    SOURCE_SCRIPT=$(realpath "$0")
    sudo rm -f "$TARGET_BIN"
    sudo cp "$SOURCE_SCRIPT" "$TARGET_BIN" && sudo chmod +x "$TARGET_BIN"
    echo "✅ Reinstall Successful."; exit 0
fi

# --- 4. EXECUTION LOGIC ---
[ -z "$WAYLAND_DISPLAY" ] && tool="xdotool" || tool="ydotool"
delay=0; use_osd=0; mouse_x=""; mouse_y=""; mouse_click=""; hud_color="#00FFFF"

while [[ $# -gt 0 ]]; do
    case "$1" in
        --osd) use_osd=1; shift ;;
        --color) hud_color="$2"; shift 2 ;;
        -m|--move) mouse_x="$2"; mouse_y="$3"; shift 3 ;;
        -c|--click) mouse_click="$2"; shift 2 ;;
        -d|--delay) delay="$2"; shift 2 ;;
        *) break ;;
    esac
done

# --- THE SMART HUD (The Width Fix) ---
if [[ "$use_osd" -eq 1 ]] && command -v osd_cat >/dev/null 2>&1; then
    # 1. Bridge Display for XWayland
    [[ -z "$DISPLAY" ]] && export DISPLAY=$(ls /tmp/.X11-unix/X* | head -n1 | sed 's/.*X/:/')
    
    label="[Kapcode] ⚡ ${1:-"Action"}"
    
    # 2. Mathematical Indent Hack
    # We calculate the indent based on character length to "push" the text to the right 
    # without letting the background bar span the whole screen.
    char_count=${#label}
    font_width=12 # Approximate px per char for 'fixed' bold 18
    text_width=$((char_count * font_width))
    screen_width=$(get_monitor_info)
    
    # Right-side indent = Screen Width - Text Width - Margin
    dynamic_indent=$((screen_width - text_width - 60))
    
    (echo "$label" | osd_cat --pos=bottom --align=left --offset=40 --indent=$dynamic_indent \
        --colour="$hud_color" --shadow=2 --outline=1 --lines=1 \
        --font="-*-fixed-bold-r-*-*-18-*-*-*-*-*-*-*" --delay=2) &
fi

# --- CORE ACTIONS ---
[[ "$tool" == "ydotool" ]] && { pgrep -x "ydotoold" >/dev/null || { nohup ydotoold >/dev/null 2>&1 & sleep 0.5; }; }

[ "$delay" -gt 0 ] && sleep "$(awk "BEGIN {print $delay/1000}")"

[ -n "$mouse_x" ] && { [[ "$tool" = "xdotool" ]] && xdotool mousemove "$mouse_x" "$mouse_y" || ydotool move "$mouse_x" "$mouse_y"; }
if [ -n "$mouse_click" ]; then
    if [[ "$tool" == "xdotool" ]]; then xdotool click "$mouse_click"
    else
        case "$mouse_click" in 1) b="0xC0";; 2) b="0xC2";; 3) b="0xC1";; esac
        ydotool click "$b"
    fi
fi

# Key Execution Logic... (Standard Sequence)
# --- 4. EXECUTION LOGIC ---
[ -z "$WAYLAND_DISPLAY" ] && tool="xdotool" || tool="ydotool"
delay=0; use_osd=0; mouse_x=""; mouse_y=""; mouse_click=""; hud_color="#00FFFF"

while [[ $# -gt 0 ]]; do
    case "$1" in
        --osd) use_osd=1; shift ;;
        --color) hud_color="$2"; shift 2 ;;
        -m|--move) mouse_x="$2"; mouse_y="$3"; shift 3 ;;
        -c|--click) mouse_click="$2"; shift 2 ;;
        -d|--delay) delay="$2"; shift 2 ;;
        *) break ;;
    esac
done

[[ "$tool" == "ydotool" ]] && { pgrep -x "ydotoold" >/dev/null || { nohup ydotoold >/dev/null 2>&1 & sleep 0.5; }; }

shortcut="$1"
read -ra keys <<< "$shortcut"

# --- THE KAPCODE HUD (Strict Floating Style) ---
if [[ "$use_osd" -eq 1 ]] && command -v osd_cat >/dev/null 2>&1; then
    [[ -z "$DISPLAY" ]] && export DISPLAY=$(ls /tmp/.X11-unix/X* | head -n1 | sed 's/.*X/:/')
    
    label="${shortcut:-"Action"}"
    # FIX: Explicitly setting outline and shadow while ensuring no background flags are passed.
    # Align Left + Pos Bottom + Outline = Floating text effect.
    (echo "[Kapcode] ⚡ $label" | osd_cat --pos=bottom --align=left --offset=40 --indent=40 \
        --colour="$hud_color" --shadow=2 --outline=1 --lines=1 \
        --font="-*-fixed-bold-r-*-*-20-*-*-*-*-*-*-*" --delay=2) &
fi

[ "$delay" -gt 0 ] && sleep "$(awk "BEGIN {print $delay/1000}")"

# Execute Mouse/Key Logic
[ -n "$mouse_x" ] && { [[ "$tool" = "xdotool" ]] && xdotool mousemove "$mouse_x" "$mouse_y" || ydotool move "$mouse_x" "$mouse_y"; }
if [ -n "$mouse_click" ]; then
    [[ "$tool" == "xdotool" ]] && xdotool click "$mouse_click" || {
        case "$mouse_click" in 1) b="0xC0";; 2) b="0xC2";; 3) b="0xC1";; esac
        ydotool click "$b"
    }
fi
if [ ${#keys[@]} -gt 0 ]; then
    if [[ "$tool" == "ydotool" ]]; then
        seq=""; for k in "${keys[@]}"; do [ -z "$seq" ] && seq="$k" || seq="$seq+$k"; done
        ydotool key "$seq"
    else
        for ((i=0; i<${#keys[@]}-1; i++)); do xdotool keydown "${keys[i]}"; done
        xdotool key "${keys[-1]}"; for ((i=${#keys[@]}-2; i>=0; i--)); do xdotool keyup "${keys[i]}"; done
    fi
fi
